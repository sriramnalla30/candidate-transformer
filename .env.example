# Copy this file to ".env" in your project root and paste your key after the = sign.
# Get a FREE key at https://console.groq.com  ->  API Keys  ->  Create API Key
# The project runs WITHOUT a key too (it uses a deterministic fallback), so this is optional.

GROQ_API_KEY=

# Optional: override the model (defaults are fine)
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: default phone region for numbers without a country code
DEFAULT_PHONE_REGION=IN
